/crates/tine-app/linux-signing-private.asc

# Generated packaging outputs
/packaging/python/build/
/packaging/python/python/*.egg-info/

# Desktop shell (Tauri) — tracked, but a few paths are build artifacts:
#   - tauri.conf.json is regenerated by crates/tine-app/build.rs from the template
#   - gen/schemas/ is emitted by tauri-build from capabilities
#   - resources/runtime/ is populated by scripts/release/fetch_app_runtime.py
/crates/tine-app/tauri.conf.json
/crates/tine-app/gen/schemas/
/crates/tine-app/resources/runtime/

# Ignore markdown docs except README files
*.md
!README.md
!README*.md
!CONTRIBUTING.md
